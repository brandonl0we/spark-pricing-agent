# mock is safest for local development. Change to zapier when the hook is ready.
PRICING_PROVIDER=mock

# Required when PRICING_PROVIDER=zapier.
ZAPIER_PRICING_WEBHOOK_URL=

# Optional shared secret sent as X-Pricing-Secret to Zapier.
ZAPIER_PRICING_SHARED_SECRET=

# Optional, shown in API responses and useful for audit/debugging.
PRICING_MODEL_VERSION=mock-2026-05
